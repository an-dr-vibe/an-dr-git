{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2022"
    ],
    "types": [
      "node"
    ]
  },
  "include": [
    "src/main/**/*.ts",
    "src/main/**/*.cts",
    "src/main/**/*.d.ts",
    "src/shared/**/*.ts"
  ]
}
