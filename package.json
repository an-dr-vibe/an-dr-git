{
  "name": "an-dr-git",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cross-platform desktop Git client scaffold for Electron, React, and TypeScript.",
  "main": "dist/main/index.js",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "clean": "rimraf coverage dist",
    "build": "npm run clean && npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.build.json",
    "build:renderer": "vite build",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/node": "^20.17.30",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.1.1",
    "electron": "^31.7.7",
    "eslint": "^9.23.0",
    "globals": "^15.15.0",
    "jsdom": "^25.0.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0",
    "vite": "^5.4.14",
    "vitest": "^3.1.1"
  }
}
